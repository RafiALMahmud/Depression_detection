APP_NAME=MindWell API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/mindwell

JWT_SECRET_KEY=please-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INVITATION_CODE_SECRET=please-change-this-in-production
INVITATION_EXPIRE_DAYS=7
FRONTEND_BASE_URL=http://localhost:5173
SERVE_FRONTEND=false
FRONTEND_DIST_DIR=dist

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_SEED=true
SEED_SEND_EMAILS=false

VISION_MODEL_WEIGHTS_PATH=backend/app/models/efficientface_rafdb.pth
VISION_MODEL_ARCHITECTURE=efficientface
# Leave blank for EfficientFace. This is only used when overriding the MobileNetV3 classifier head.
VISION_CLASSIFIER_HIDDEN_DIM=
VISION_CLASS_LABELS=neutral,happy,sad,surprise,fear,disgust,angry
VISION_INPUT_SIZE=224
VISION_MAX_FRAMES_PER_REQUEST=60
VISION_STRICT_MODEL_LOAD=true

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@example.com
MAIL_FROM_NAME=MindWell
